{
   "version": "0.2.0",
   "configurations": [
      {
         "type": "pwa-node",
         "request": "launch",
         "name": "Debug Current Vitest File",
         "autoAttachChildProcesses": true,
         "skipFiles": [
            "<node_internals>/**",
            "**/node_modules/**"
         ],
         "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
         "cwd": "${workspaceFolder}",
         "args": [
            "run",
            "${file}",
            "--no-file-parallelism",
            "--test-timeout=0"
         ],
         "smartStep = true": true,
         "console": "integratedTerminal"
      }
   ]
}
